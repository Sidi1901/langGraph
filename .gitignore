# .gitignore

# ----------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL)
# ----------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.json

# ----------------------------------------------------------------------
# Python Virtual Environments
# ----------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# ----------------------------------------------------------------------
# Python Cache and Compiled Bytecode
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------------------
# IDEs and Editors
# ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------------------------------------------------
# Testing and Evaluation (DeepEval / Pytest)
# ----------------------------------------------------------------------
.deepeval/
.pytest_cache/
htmlcov/
.coverage